<td style="width:30px">
<table style="border-radius: 24px; -moz-border-radius: 24px; -webkit-border-radius: 24px; -khtml-border-radius: 24px; -icab-border-radius: 24px; -o-border-radius: 24px;; background: #D89DB7; border: 1px solid #82445E; float:right;">
